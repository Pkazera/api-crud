# Conexão com MySQL
# Formato: mysql+pymysql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=mysql+pymysql://root:suasenha@localhost:3306/crud_db

# Chave secreta para gerar tokens JWT (troque por algo aleatório)
JWT_SECRET=troque-por-uma-chave-secreta-forte

# Credenciais do usuário admin
ADMIN_USER=admin
ADMIN_PASS=admin123
